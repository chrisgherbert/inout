# Copy this file to scripts/release.env and fill in real values.
# This file is safe to commit; scripts/release.env is gitignored.

# Apple Developer Team ID (10 chars), e.g. ABCD123456
export TEAM_ID="YOUR_TEAM_ID"

# Developer ID Application cert common name
# Example:
# Developer ID Application: Center Enterprises, Inc. (YOUR_TEAM_ID)
export DEV_ID_APP="Developer ID Application: COMPANY NAME (YOUR_TEAM_ID)"

# notarytool keychain profile name
# Create once:
# xcrun notarytool store-credentials "$AC_PROFILE" \
#   --apple-id "you@company.com" \
#   --team-id "$TEAM_ID" \
#   --password "app-specific-password"
export AC_PROFILE="notarytool-profile-name"

# Optional override for release ffmpeg source and checksum pin.
# Defaults are:
#   BUNDLED_FFMPEG_PATH=vendor/ffmpeg/macos-arm64/ffmpeg
#   BUNDLED_FFMPEG_SHA_FILE=vendor/ffmpeg/macos-arm64/ffmpeg.sha256
# If BUNDLED_FFMPEG_SHA256 is set, it overrides SHA file lookup.
# export BUNDLED_FFMPEG_PATH="/absolute/path/to/ffmpeg"
# export BUNDLED_FFMPEG_SHA_FILE="/absolute/path/to/ffmpeg.sha256"
# export BUNDLED_FFMPEG_SHA256="abc123..."
